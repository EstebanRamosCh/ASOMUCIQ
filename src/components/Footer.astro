---
import { getLangFromUrl, useTranslations, type UiType } from "../i18n/utils";
import LangSwitch from "./LangSwitch.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang as UiType);
---

<footer class="bg-gray py-4">
  <div class="container">
    <div class="flex justify-between items-center">
      <a
        data-astro-prefetch
        href={`/${lang}/`}
        class="flex gap-1 font-semibold text-white"
        ><img
          src="/Logo ASOMUCIQ2.png"
          alt="logo"
          width="200"
          height="200"
          loading="eager"
        />ASOMUCIQ</a
      >
      <LangSwitch />
    </div>
    <small class="text-white">
      &copy; {t("footer.copyright", new Date().getFullYear())}
      {t("footer.createdBy")}
      <b
        ><a href="https://esteban-ramos-ch.com/" target="_blank" class="link"
          >Esteban Ramos Chavarriaga</a
        ></b
      >
      {t("footer.createdBy2")}
    </small>
  </div>
</footer>
